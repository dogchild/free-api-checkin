# Comma-separated provider IDs to run. Only providers registered in src/providers/index.ts can be selected.
CHECKIN_ENABLED=example
# To run the ice.v.ua provider, set CHECKIN_ENABLED=ice or include it in the list.
# CHECKIN_ENABLED=ice

# Optional global dry-run switch for local/manual verification.
# Omit it to default to false; set it to true only when you want dry-run behavior.
# CHECKIN_DRY_RUN=true

# Provider-specific environment variables should be added here as new sites are implemented.
# Use an uppercase prefix per site so secrets remain easy to manage in GitHub Actions.

# ice.v.ua custom pages embed signv with the current main-site auth token and user id.
# Copy both values from localStorage after a successful manual login.
ICE_SUB2API_AUTH_TOKEN=
ICE_SUB2API_USER_ID=

# Example future variables:
# EXAMPLE_COOKIE=
# EXAMPLE_TOKEN=
# SITE_A_COOKIE=
# SITE_A_TOKEN=
