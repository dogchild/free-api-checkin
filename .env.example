# Comma-separated provider IDs to run. Only providers registered in src/providers/index.ts can be selected.
CHECKIN_ENABLED=example
# To run the ice.v.ua provider, set CHECKIN_ENABLED=ice or include it in the list.
# CHECKIN_ENABLED=ice

# Optional global dry-run switch. The CLI flag --dry-run also enables dry-run mode.
CHECKIN_DRY_RUN=false

# Provider-specific environment variables should be added here as new sites are implemented.
# Use an uppercase prefix per site so secrets remain easy to manage in GitHub Actions.

# ice.v.ua stores its own sub2api refresh token after a successful manual login.
# Reusing that token avoids automating the upstream Google -> LinuxDo OAuth chain.
ICE_SUB2API_REFRESH_TOKEN=

# Example future variables:
# EXAMPLE_COOKIE=
# EXAMPLE_TOKEN=
# SITE_A_COOKIE=
# SITE_A_TOKEN=
